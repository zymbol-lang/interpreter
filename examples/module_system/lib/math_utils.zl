# math_utils

#> {
    add
    subtract
    multiply
    PI
    E
}

// Public constants
PI := 3.14159
E := 2.71828

// Private constant (not exported)
INTERNAL_PRECISION := 0.0001

// Public functions
add(a, b) {
    <~ a + b
}

subtract(a, b) {
    <~ a - b
}

multiply(a, b) {
    <~ a * b
}

// Private function (not exported)
internal_round(value) {
    <~ value
}
