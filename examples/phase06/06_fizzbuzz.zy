// Phase 6: FizzBuzz using loops
// Classic FizzBuzz from 1 to 15

n = 1
@ n <= 15 {
    div3 = n % 3 == 0
    div5 = n % 5 == 0

    // Check divisibility
    ? div3 {
        ? div5 {
            >> "FizzBuzz" ¶
        }
        _{
            >> "Fizz" ¶
        }
    }
    _{
        ? div5 {
            >> "Buzz" ¶
        }
        _{
            >> n ¶
        }
    }

    n = n + 1
}
