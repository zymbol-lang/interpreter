// Phase 6: TIMES with break and continue

>> "TIMES with break (should stop at 3):" ¶
count = 0

@ 10 {
    count = count + 1

    ? count == 3 {
        >> "Breaking at " count ¶
        @!
    }

    >> count " "
}

¶
>> "Final count: " count ¶
¶

>> "TIMES with continue (skip evens):" ¶
i = 0

@ 10 {
    i = i + 1

    ? i % 2 == 0 {
        @>  // Skip even numbers
    }

    >> i " "
}

¶
>> "Done!" ¶
