// Numeral system: Arabic-Indic (U+0660–U+0669)
// Script: Arabic-Indic
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Arabic-Indic) ---
// ١٢
// ٤
// ٣٢
// ٢
// ٢
// ٦٤
// -٨
// -٤
// -٣٢
// ٤.٧٥
// ٢.٢٥
// ٤.٣٧٥
// ٢.٨
// ١٢.٢٥
// -١.٢٥
// ١٠٨
// ٤٠٠
// ٢٥٥
// --- Booleans (in script mode) ---
// #١
// #٠
// #١
// #٠
// #١
// #٠

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ٨
b = ٤
c = ٣
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ٢) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ٣.٥
g = ١.٢٥
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ٢) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ١٠٠
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Arabic-Indic) ---" ¶

#٠٩#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ٢) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ٢) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (١٢ > ٤)
cmp_lt = (٤ > ١٢)
>> cmp_gt ¶
>> cmp_lt ¶
>> #١ ¶
>> #٠ ¶

// Restore ASCII mode
#09#
