// Numeral system: Cham (U+AA50–U+AA59)
// Script: Cham
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Cham) ---
// ꩑꩒
// ꩔
// ꩓꩒
// ꩒
// ꩒
// ꩖꩔
// -꩘
// -꩔
// -꩓꩒
// ꩔.꩗꩕
// ꩒.꩒꩕
// ꩔.꩓꩗꩕
// ꩒.꩘
// ꩑꩒.꩒꩕
// -꩑.꩒꩕
// ꩑꩐꩘
// ꩔꩐꩐
// ꩒꩕꩕
// --- Booleans (in script mode) ---
// #꩑
// #꩐
// #꩑
// #꩐
// #꩑
// #꩐

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ꩘
b = ꩔
c = ꩓
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꩒) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ꩓.꩕
g = ꩑.꩒꩕
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꩒) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ꩑꩐꩐
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Cham) ---" ¶

#꩐꩙#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꩒) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꩒) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (꩑꩒ > ꩔)
cmp_lt = (꩔ > ꩑꩒)
>> cmp_gt ¶
>> cmp_lt ¶
>> #꩑ ¶
>> #꩐ ¶

// Restore ASCII mode
#09#
