// Numeral system: Tai Tham Hora (U+1A80–U+1A89)
// Script: Tai Tham Hora
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Tai Tham Hora) ---
// ᪁᪂
// ᪄
// ᪃᪂
// ᪂
// ᪂
// ᪆᪄
// -᪈
// -᪄
// -᪃᪂
// ᪄.᪇᪅
// ᪂.᪂᪅
// ᪄.᪃᪇᪅
// ᪂.᪈
// ᪁᪂.᪂᪅
// -᪁.᪂᪅
// ᪁᪀᪈
// ᪄᪀᪀
// ᪂᪅᪅
// --- Booleans (in script mode) ---
// #᪁
// #᪀
// #᪁
// #᪀
// #᪁
// #᪀

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ᪈
b = ᪄
c = ᪃
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᪂) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ᪃.᪅
g = ᪁.᪂᪅
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᪂) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ᪁᪀᪀
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Tai Tham Hora) ---" ¶

#᪀᪉#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᪂) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᪂) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (᪁᪂ > ᪄)
cmp_lt = (᪄ > ᪁᪂)
>> cmp_gt ¶
>> cmp_lt ¶
>> #᪁ ¶
>> #᪀ ¶

// Restore ASCII mode
#09#
