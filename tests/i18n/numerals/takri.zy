// -𑛁.𑛂𑛅
// 𑛁𑛀𑛈
// 𑛄𑛀𑛀
// 𑛂𑛅𑛅
// --- Booleans (in script mode) ---
// #𑛁
// #𑛀
// #𑛁
// #𑛀
// #𑛁
// #𑛀

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = 𑛈
b = 𑛄
c = 𑛃
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑛂) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 𑛃.𑛅
g = 𑛁.𑛂𑛅
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑛂) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = 𑛁𑛀𑛀
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Takri) ---" ¶

#𑛀𑛉#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑛂) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑛂) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (𑛁𑛂 > 𑛄)
cmp_lt = (𑛄 > 𑛁𑛂)
>> cmp_gt ¶
>> cmp_lt ¶
>> #𑛁 ¶
>> #𑛀 ¶

// Restore ASCII mode
#09#
