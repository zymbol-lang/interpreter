// Numeral system: Thai (U+0E50–U+0E59)
// Script: Thai
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Thai) ---
// ๑๒
// ๔
// ๓๒
// ๒
// ๒
// ๖๔
// -๘
// -๔
// -๓๒
// ๔.๗๕
// ๒.๒๕
// ๔.๓๗๕
// ๒.๘
// ๑๒.๒๕
// -๑.๒๕
// ๑๐๘
// ๔๐๐
// ๒๕๕
// --- Booleans (in script mode) ---
// #๑
// #๐
// #๑
// #๐
// #๑
// #๐

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ๘
b = ๔
c = ๓
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ๒) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ๓.๕
g = ๑.๒๕
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ๒) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ๑๐๐
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Thai) ---" ¶

#๐๙#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ๒) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ๒) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (๑๒ > ๔)
cmp_lt = (๔ > ๑๒)
>> cmp_gt ¶
>> cmp_lt ¶
>> #๑ ¶
>> #๐ ¶

