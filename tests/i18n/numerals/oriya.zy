// Numeral system: Oriya (U+0B66–U+0B6F)
// Script: Oriya
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Oriya) ---
// ୧୨
// ୪
// ୩୨
// ୨
// ୨
// ୬୪
// -୮
// -୪
// -୩୨
// ୪.୭୫
// ୨.୨୫
// ୪.୩୭୫
// ୨.୮
// ୧୨.୨୫
// -୧.୨୫
// ୧୦୮
// ୪୦୦
// ୨୫୫
// --- Booleans (in script mode) ---
// #୧
// #୦
// #୧
// #୦
// #୧
// #୦

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ୮
b = ୪
c = ୩
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ୨) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ୩.୫
g = ୧.୨୫
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ୨) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ୧୦୦
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Oriya) ---" ¶

#୦୯#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ୨) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ୨) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (୧୨ > ୪)
cmp_lt = (୪ > ୧୨)
>> cmp_gt ¶
>> cmp_lt ¶
>> #୧ ¶
>> #୦ ¶

// Restore ASCII mode
#09#
