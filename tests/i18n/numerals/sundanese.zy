// Numeral system: Sundanese (U+1BB0–U+1BB9)
// Script: Sundanese
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Sundanese) ---
// ᮱᮲
// ᮴
// ᮳᮲
// ᮲
// ᮲
// ᮶᮴
// -᮸
// -᮴
// -᮳᮲
// ᮴.᮷᮵
// ᮲.᮲᮵
// ᮴.᮳᮷᮵
// ᮲.᮸
// ᮱᮲.᮲᮵
// -᮱.᮲᮵
// ᮱᮰᮸
// ᮴᮰᮰
// ᮲᮵᮵
// --- Booleans (in script mode) ---
// #᮱
// #᮰
// #᮱
// #᮰
// #᮱
// #᮰

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ᮸
b = ᮴
c = ᮳
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᮲) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ᮳.᮵
g = ᮱.᮲᮵
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᮲) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ᮱᮰᮰
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Sundanese) ---" ¶

#᮰᮹#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᮲) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᮲) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (᮱᮲ > ᮴)
cmp_lt = (᮴ > ᮱᮲)
>> cmp_gt ¶
>> cmp_lt ¶
>> #᮱ ¶
>> #᮰ ¶

// Restore ASCII mode
#09#
