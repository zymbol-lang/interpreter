c = 𑵓
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑵒) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
