>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 𑵓.𑵕
g = 𑵑.𑵒𑵕
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
