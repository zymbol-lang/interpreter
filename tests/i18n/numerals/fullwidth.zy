>> "--- Large numbers ---" ¶

h = １００
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Fullwidth) ---" ¶

#０９#

>> (a + b) ¶
