// Numeral system: Mongolian (U+1810–U+1819)
// Script: Mongolian
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Mongolian) ---
// ᠑᠒
// ᠔
// ᠓᠒
// ᠒
// ᠒
// ᠖᠔
// -᠘
// -᠔
// -᠓᠒
// ᠔.᠗᠕
// ᠒.᠒᠕
// ᠔.᠓᠗᠕
// ᠒.᠘
// ᠑᠒.᠒᠕
// -᠑.᠒᠕
// ᠑᠐᠘
// ᠔᠐᠐
// ᠒᠕᠕
// --- Booleans (in script mode) ---
// #᠑
// #᠐
// #᠑
// #᠐
// #᠑
// #᠐

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ᠘
b = ᠔
c = ᠓
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᠒) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ᠓.᠕
g = ᠑.᠒᠕
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᠒) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ᠑᠐᠐
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Mongolian) ---" ¶

#᠐᠙#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᠒) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᠒) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (᠑᠒ > ᠔)
cmp_lt = (᠔ > ᠑᠒)
>> cmp_gt ¶
>> cmp_lt ¶
>> #᠑ ¶
>> #᠐ ¶

// Restore ASCII mode
#09#
