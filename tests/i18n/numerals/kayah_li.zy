// Numeral system: Kayah Li (U+A900–U+A909)
// Script: Kayah Li
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Kayah Li) ---
// ꤁꤂
// ꤄
// ꤃꤂
// ꤂
// ꤂
// ꤆꤄
// -꤈
// -꤄
// -꤃꤂
// ꤄.꤇꤅
// ꤂.꤂꤅
// ꤄.꤃꤇꤅
// ꤂.꤈
// ꤁꤂.꤂꤅
// -꤁.꤂꤅
// ꤁꤀꤈
// ꤄꤀꤀
// ꤂꤅꤅
// --- Booleans (in script mode) ---
// #꤁
// #꤀
// #꤁
// #꤀
// #꤁
// #꤀

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ꤈
b = ꤄
c = ꤃
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꤂) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ꤃.꤅
g = ꤁.꤂꤅
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꤂) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ꤁꤀꤀
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Kayah Li) ---" ¶

#꤀꤉#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꤂) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꤂) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (꤁꤂ > ꤄)
cmp_lt = (꤄ > ꤁꤂)
>> cmp_gt ¶
>> cmp_lt ¶
>> #꤁ ¶
>> #꤀ ¶

// Restore ASCII mode
#09#
