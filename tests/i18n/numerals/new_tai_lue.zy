>> "--- Float / decimal ---" ¶

f = ᧓.᧕
g = ᧑.᧒᧕
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᧒) ¶
