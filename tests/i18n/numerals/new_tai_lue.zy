>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᧒) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (᧑᧒ > ᧔)
cmp_lt = (᧔ > ᧑᧒)
>> cmp_gt ¶
>> cmp_lt ¶
>> #᧑ ¶
