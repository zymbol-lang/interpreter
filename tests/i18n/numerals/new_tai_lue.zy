>> "--- Large numbers ---" ¶

h = ᧑᧐᧐
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (New Tai Lue) ---" ¶

#᧐᧙#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᧒) ¶
>> (-a) ¶
