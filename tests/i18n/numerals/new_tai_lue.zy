// #᧐
// #᧑
// #᧐
// #᧑
// #᧐

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ᧘
b = ᧔
c = ᧓
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᧒) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
