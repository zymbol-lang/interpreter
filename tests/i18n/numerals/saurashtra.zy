// Numeral system: Saurashtra (U+A8D0–U+A8D9)
// Script: Saurashtra
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Saurashtra) ---
// ꣑꣒
// ꣔
// ꣓꣒
// ꣒
// ꣒
// ꣖꣔
// -꣘
// -꣔
// -꣓꣒
// ꣔.꣗꣕
// ꣒.꣒꣕
// ꣔.꣓꣗꣕
// ꣒.꣘
// ꣑꣒.꣒꣕
// -꣑.꣒꣕
// ꣑꣐꣘
// ꣔꣐꣐
// ꣒꣕꣕
// --- Booleans (in script mode) ---
// #꣑
// #꣐
// #꣑
// #꣐
// #꣑
// #꣐

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ꣘
b = ꣔
c = ꣓
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꣒) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ꣓.꣕
g = ꣑.꣒꣕
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꣒) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ꣑꣐꣐
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Saurashtra) ---" ¶

#꣐꣙#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꣒) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꣒) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (꣑꣒ > ꣔)
cmp_lt = (꣔ > ꣑꣒)
>> cmp_gt ¶
>> cmp_lt ¶
>> #꣑ ¶
>> #꣐ ¶

// Restore ASCII mode
#09#
