// Numeral system: Nag Mundari (U+1E4F0–U+1E4F9)
// Script: Nag Mundari
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Nag Mundari) ---
// 𞓱𞓲
// 𞓴
// 𞓳𞓲
// 𞓲
// 𞓲
// 𞓶𞓴
// -𞓸
// -𞓴
// -𞓳𞓲
// 𞓴.𞓷𞓵
// 𞓲.𞓲𞓵
// 𞓴.𞓳𞓷𞓵
// 𞓲.𞓸
// 𞓱𞓲.𞓲𞓵
// -𞓱.𞓲𞓵
// 𞓱𞓰𞓸
// 𞓴𞓰𞓰
// 𞓲𞓵𞓵
// --- Booleans (in script mode) ---
// #𞓱
// #𞓰
// #𞓱
// #𞓰
// #𞓱
// #𞓰

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = 𞓸
b = 𞓴
c = 𞓳
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𞓲) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 𞓳.𞓵
g = 𞓱.𞓲𞓵
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𞓲) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = 𞓱𞓰𞓰
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Nag Mundari) ---" ¶

#𞓰𞓹#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𞓲) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𞓲) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (𞓱𞓲 > 𞓴)
cmp_lt = (𞓴 > 𞓱𞓲)
>> cmp_gt ¶
>> cmp_lt ¶
>> #𞓱 ¶
>> #𞓰 ¶

// Restore ASCII mode
#09#
