// Numeral system: Myanmar (U+1040–U+1049)
// Script: Myanmar
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Myanmar) ---
// ၁၂
// ၄
// ၃၂
// ၂
// ၂
// ၆၄
// -၈
// -၄
// -၃၂
// ၄.၇၅
// ၂.၂၅
// ၄.၃၇၅
// ၂.၈
// ၁၂.၂၅
// -၁.၂၅
// ၁၀၈
// ၄၀၀
// ၂၅၅
// --- Booleans (in script mode) ---
// #၁
// #၀
// #၁
// #၀
// #၁
// #၀

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ၈
b = ၄
c = ၃
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ၂) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ၃.၅
g = ၁.၂၅
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ၂) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ၁၀၀
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Myanmar) ---" ¶

#၀၉#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ၂) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ၂) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (၁၂ > ၄)
cmp_lt = (၄ > ၁၂)
>> cmp_gt ¶
>> cmp_lt ¶
>> #၁ ¶
>> #၀ ¶

// Restore ASCII mode
#09#
