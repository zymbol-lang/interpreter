>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑣢) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (𑣡𑣢 > 𑣤)
cmp_lt = (𑣤 > 𑣡𑣢)
>> cmp_gt ¶
>> cmp_lt ¶
>> #𑣡 ¶
>> #𑣠 ¶

