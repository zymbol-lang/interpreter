>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = 𑣨
b = 𑣤
c = 𑣣
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑣢) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 𑣣.𑣥
g = 𑣡.𑣢𑣥
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑣢) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = 𑣡𑣠𑣠
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Warang Citi) ---" ¶

#𑣠𑣩#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑣢) ¶
>> (-a) ¶
