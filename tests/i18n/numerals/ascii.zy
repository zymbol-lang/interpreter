// Numeral system: ASCII (U+0030–U+0039)
// Script: ASCII
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (ASCII) ---
// 12
// 4
// 32
// 2
// 2
// 64
// -8
// -4
// -32
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// 108
// 400
// 255
// --- Booleans (in script mode) ---
// #1
// #0
// #1
// #0
// #1
// #0

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = 8
b = 4
c = 3
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 2) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 3.5
g = 1.25
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 2) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = 100
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (ASCII) ---" ¶

#09#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 2) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 2) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (12 > 4)
cmp_lt = (4 > 12)
>> cmp_gt ¶
>> cmp_lt ¶
>> #1 ¶
>> #0 ¶

// Restore ASCII mode
#09#
