>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = 𑋸
b = 𑋴
c = 𑋳
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑋲) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 𑋳.𑋵
g = 𑋱.𑋲𑋵
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑋲) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = 𑋱𑋰𑋰
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Khudawadi) ---" ¶

#𑋰𑋹#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑋲) ¶
>> (-a) ¶
