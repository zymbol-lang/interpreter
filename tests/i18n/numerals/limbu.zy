// ᥈.᥈᥋
// ᥊.᥉᥍᥋
// ᥈.᥎
// ᥇᥈.᥈᥋
// -᥇.᥈᥋
// ᥇᥆᥎
// ᥊᥆᥆
// ᥈᥋᥋
// --- Booleans (in script mode) ---
// #᥇
// #᥆
// #᥇
// #᥆
// #᥇
// #᥆

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ᥎
b = ᥊
c = ᥉
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᥈) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ᥉.᥋
g = ᥇.᥈᥋
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᥈) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ᥇᥆᥆
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Limbu) ---" ¶

#᥆᥏#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᥈) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᥈) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (᥇᥈ > ᥊)
cmp_lt = (᥊ > ᥇᥈)
>> cmp_gt ¶
>> cmp_lt ¶
>> #᥇ ¶
>> #᥆ ¶

// Restore ASCII mode
#09#
