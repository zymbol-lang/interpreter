// Numeral system: Nyiakeng Puachue Hmong (U+1E140–U+1E149)
// Script: Nyiakeng Puachue Hmong
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Nyiakeng Puachue Hmong) ---
// 𞅁𞅂
// 𞅄
// 𞅃𞅂
// 𞅂
// 𞅂
// 𞅆𞅄
// -𞅈
// -𞅄
// -𞅃𞅂
// 𞅄.𞅇𞅅
// 𞅂.𞅂𞅅
// 𞅄.𞅃𞅇𞅅
// 𞅂.𞅈
// 𞅁𞅂.𞅂𞅅
// -𞅁.𞅂𞅅
// 𞅁𞅀𞅈
// 𞅄𞅀𞅀
// 𞅂𞅅𞅅
// --- Booleans (in script mode) ---
// #𞅁
// #𞅀
// #𞅁
// #𞅀
// #𞅁
// #𞅀

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = 𞅈
b = 𞅄
c = 𞅃
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𞅂) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 𞅃.𞅅
g = 𞅁.𞅂𞅅
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𞅂) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = 𞅁𞅀𞅀
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Nyiakeng Puachue Hmong) ---" ¶

#𞅀𞅉#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𞅂) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𞅂) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (𞅁𞅂 > 𞅄)
cmp_lt = (𞅄 > 𞅁𞅂)
>> cmp_gt ¶
>> cmp_lt ¶
>> #𞅁 ¶
>> #𞅀 ¶

// Restore ASCII mode
#09#
