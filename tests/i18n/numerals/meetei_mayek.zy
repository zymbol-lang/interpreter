// Numeral system: Meetei Mayek (U+ABF0–U+ABF9)
// Script: Meetei Mayek
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Meetei Mayek) ---
// ꯱꯲
// ꯴
// ꯳꯲
// ꯲
// ꯲
// ꯶꯴
// -꯸
// -꯴
// -꯳꯲
// ꯴.꯷꯵
// ꯲.꯲꯵
// ꯴.꯳꯷꯵
// ꯲.꯸
// ꯱꯲.꯲꯵
// -꯱.꯲꯵
// ꯱꯰꯸
// ꯴꯰꯰
// ꯲꯵꯵
// --- Booleans (in script mode) ---
// #꯱
// #꯰
// #꯱
// #꯰
// #꯱
// #꯰

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ꯸
b = ꯴
c = ꯳
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꯲) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ꯳.꯵
g = ꯱.꯲꯵
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꯲) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ꯱꯰꯰
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Meetei Mayek) ---" ¶

#꯰꯹#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꯲) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꯲) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (꯱꯲ > ꯴)
cmp_lt = (꯴ > ꯱꯲)
>> cmp_gt ¶
>> cmp_lt ¶
>> #꯱ ¶
>> #꯰ ¶

// Restore ASCII mode
#09#
