>> "--- Large numbers ---" ¶

h = ᱑᱐᱐
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Ol Chiki) ---" ¶

#᱐᱙#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᱒) ¶
>> (-a) ¶
