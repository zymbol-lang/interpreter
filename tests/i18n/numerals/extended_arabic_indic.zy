// Numeral system: Extended Arabic-Indic (U+06F0–U+06F9)
// Script: Extended Arabic-Indic
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Extended Arabic-Indic) ---
// ۱۲
// ۴
// ۳۲
// ۲
// ۲
// ۶۴
// -۸
// -۴
// -۳۲
// ۴.۷۵
// ۲.۲۵
// ۴.۳۷۵
// ۲.۸
// ۱۲.۲۵
// -۱.۲۵
// ۱۰۸
// ۴۰۰
// ۲۵۵
// --- Booleans (in script mode) ---
// #۱
// #۰
// #۱
// #۰
// #۱
// #۰

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ۸
b = ۴
c = ۳
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ۲) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ۳.۵
g = ۱.۲۵
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ۲) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ۱۰۰
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Extended Arabic-Indic) ---" ¶

#۰۹#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ۲) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ۲) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (۱۲ > ۴)
cmp_lt = (۴ > ۱۲)
>> cmp_gt ¶
>> cmp_lt ¶
>> #۱ ¶
>> #۰ ¶

// Restore ASCII mode
#09#
