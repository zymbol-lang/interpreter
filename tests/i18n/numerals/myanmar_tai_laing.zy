// Numeral system: Myanmar Tai Laing (U+A9F0–U+A9F9)
// Script: Myanmar Tai Laing
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Myanmar Tai Laing) ---
// ꧱꧲
// ꧴
// ꧳꧲
// ꧲
// ꧲
// ꧶꧴
// -꧸
// -꧴
// -꧳꧲
// ꧴.꧷꧵
// ꧲.꧲꧵
// ꧴.꧳꧷꧵
// ꧲.꧸
// ꧱꧲.꧲꧵
// -꧱.꧲꧵
// ꧱꧰꧸
// ꧴꧰꧰
// ꧲꧵꧵
// --- Booleans (in script mode) ---
// #꧱
// #꧰
// #꧱
// #꧰
// #꧱
// #꧰

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ꧸
b = ꧴
c = ꧳
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꧲) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ꧳.꧵
g = ꧱.꧲꧵
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꧲) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ꧱꧰꧰
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Myanmar Tai Laing) ---" ¶

#꧰꧹#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ꧲) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ꧲) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (꧱꧲ > ꧴)
cmp_lt = (꧴ > ꧱꧲)
>> cmp_gt ¶
>> cmp_lt ¶
>> #꧱ ¶
>> #꧰ ¶

// Restore ASCII mode
#09#
