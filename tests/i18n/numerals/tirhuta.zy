// Numeral system: Tirhuta (U+114D0–U+114D9)
// Script: Tirhuta
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Tirhuta) ---
// 𑓑𑓒
// 𑓔
// 𑓓𑓒
// 𑓒
// 𑓒
// 𑓖𑓔
// -𑓘
// -𑓔
// -𑓓𑓒
// 𑓔.𑓗𑓕
// 𑓒.𑓒𑓕
// 𑓔.𑓓𑓗𑓕
// 𑓒.𑓘
// 𑓑𑓒.𑓒𑓕
// -𑓑.𑓒𑓕
// 𑓑𑓐𑓘
// 𑓔𑓐𑓐
// 𑓒𑓕𑓕
// --- Booleans (in script mode) ---
// #𑓑
// #𑓐
// #𑓑
// #𑓐
// #𑓑
// #𑓐

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = 𑓘
b = 𑓔
c = 𑓓
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑓒) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 𑓓.𑓕
g = 𑓑.𑓒𑓕
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑓒) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = 𑓑𑓐𑓐
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Tirhuta) ---" ¶

#𑓐𑓙#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑓒) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑓒) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (𑓑𑓒 > 𑓔)
cmp_lt = (𑓔 > 𑓑𑓒)
>> cmp_gt ¶
>> cmp_lt ¶
>> #𑓑 ¶
>> #𑓐 ¶

// Restore ASCII mode
#09#
