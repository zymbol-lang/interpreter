// -᱁.᱂᱅
// ᱁᱀᱈
// ᱄᱀᱀
// ᱂᱅᱅
// --- Booleans (in script mode) ---
// #᱁
// #᱀
// #᱁
// #᱀
// #᱁
// #᱀

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ᱈
b = ᱄
c = ᱃
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᱂) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ᱃.᱅
g = ᱁.᱂᱅
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᱂) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ᱁᱀᱀
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Lepcha) ---" ¶

#᱀᱉#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ᱂) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ᱂) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (᱁᱂ > ᱄)
cmp_lt = (᱄ > ᱁᱂)
>> cmp_gt ¶
>> cmp_lt ¶
>> #᱁ ¶
>> #᱀ ¶

// Restore ASCII mode
#09#
