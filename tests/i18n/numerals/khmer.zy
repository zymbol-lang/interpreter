// Numeral system: Khmer (U+17E0–U+17E9)
// Script: Khmer
//
// Tests: integer arithmetic (+ - * / % ^), negative numbers,
//        floats/decimals, exponentiation, large numbers,
//        output-mode switch, hex literals, and booleans.
//
// Values used:  a=8  b=4  c=3  f=3.5  g=1.25  h=100  exponent=2
//
// Expected output:
// --- Integer arithmetic (ASCII mode) ---
// 12
// 4
// 32
// 2
// 2
// 64
// --- Negative numbers ---
// -8
// -4
// -32
// --- Float / decimal ---
// 4.75
// 2.25
// 4.375
// 2.8
// 12.25
// -1.25
// --- Large numbers ---
// 108
// 400
// --- Hex literal 0xFF (decoded to decimal) ---
// 255
// --- Output mode (Khmer) ---
// ១២
// ៤
// ៣២
// ២
// ២
// ៦៤
// -៨
// -៤
// -៣២
// ៤.៧៥
// ២.២៥
// ៤.៣៧៥
// ២.៨
// ១២.២៥
// -១.២៥
// ១០៨
// ៤០០
// ២៥៥
// --- Booleans (in script mode) ---
// #១
// #០
// #១
// #០
// #១
// #០

>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = ៨
b = ៤
c = ៣
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ២) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = ៣.៥
g = ១.២៥
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ២) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = ១០០
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Khmer) ---" ¶

#០៩#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ ២) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ ២) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (១២ > ៤)
cmp_lt = (៤ > ១២)
>> cmp_gt ¶
>> cmp_lt ¶
>> #១ ¶
>> #០ ¶

// Restore ASCII mode
#09#
