>> "--- Integer arithmetic (ASCII mode) ---" ¶

a = 𑶨
b = 𑶤
c = 𑶣
>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑶢) ¶

>> "--- Negative numbers ---" ¶

>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶

>> "--- Float / decimal ---" ¶

f = 𑶣.𑶥
g = 𑶡.𑶢𑶥
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑶢) ¶
>> (-g) ¶

>> "--- Large numbers ---" ¶

h = 𑶡𑶠𑶠
>> (h + a) ¶
>> (h * b) ¶

>> "--- Hex literal 0xFF (decoded to decimal) ---" ¶

>> 0xFF ¶

>> "--- Output mode (Gunjala Gondi) ---" ¶

#𑶠𑶩#

>> (a + b) ¶
>> (a - b) ¶
>> (a * b) ¶
>> (a / b) ¶
>> (a % c) ¶
>> (a ^ 𑶢) ¶
>> (-a) ¶
>> (-a + b) ¶
>> (-(a * b)) ¶
>> (f + g) ¶
>> (f - g) ¶
>> (f * g) ¶
>> (f / g) ¶
>> (f ^ 𑶢) ¶
>> (-g) ¶
>> (h + a) ¶
>> (h * b) ¶
>> 0xFF ¶

>> "--- Booleans ---" ¶

>> #1 ¶
>> #0 ¶
cmp_gt = (𑶡𑶢 > 𑶤)
cmp_lt = (𑶤 > 𑶡𑶢)
>> cmp_gt ¶
>> cmp_lt ¶
>> #𑶡 ¶
>> #𑶠 ¶

// Restore ASCII mode
#09#
