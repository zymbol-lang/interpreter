<# ./matematicas/עִברִית <= מתמטיקה

תוצאה = מתמטיקה::חיבור(10, 5)
הפרש = מתמטיקה::חיסור(10, 5)
מכפלה = מתמטיקה::כפל(10, 5)
חלוקה = מתמטיקה::חילוק(10, 5)
ערך_פאי = מתמטיקה.פאי
ערך_אי = מתמטיקה.אי

>> "סכום: " תוצאה ¶
>> "הפרש: " הפרש ¶
>> "מכפלה: " מכפלה ¶
>> "חלוקה: " חלוקה ¶
>> "פאי: " ערך_פאי ¶
>> "אי: " ערך_אי ¶
