// Test: Real-world scenario - E-commerce order processing
>> "=== E-COMMERCE ORDER PROCESSING ===" ¶
¶

// Order data: (order_id, customer_id, items_count, total_price, has_discount, is_priority)
orders = [
    (1001, 501, 3, 150, #1, #0),
    (1002, 502, 1, 50, #0, #1),
    (1003, 503, 5, 300, #1, #1),
    (1004, 501, 2, 80, #0, #0),
    (1005, 504, 8, 500, #1, #1),
    (1006, 502, 1, 25, #0, #0),
    (1007, 505, 4, 200, #1, #0),
    (1008, 503, 6, 350, #1, #1),
    (1009, 506, 2, 100, #0, #1),
    (1010, 501, 3, 175, #1, #0)
]

>> "Total orders: " >> orders$# ¶
¶

// Business Rule 1: Calculate shipping cost (named function — local vars work here)
calculate_shipping(order) {
    items = order[3]
    is_priority = order[6]
    base_cost = items * 5
    ? is_priority { <~ base_cost * 2 }
    _ { <~ base_cost }
}

// Business Rule 2: Apply discount (named function — local vars work here)
apply_discount(order) {
    total = order[4]
    has_discount = order[5]
    ? has_discount { <~ total - total / 10 }
    _ { <~ total }
}

// Build processed order named tuple (named function — local vars work here)
process_order(order) {
    order_id = order[1]
    original_price = order[4]
    discounted_price = apply_discount(order)
    shipping = calculate_shipping(order)
    <~ (id: order_id, orig: original_price, disc: discounted_price, ship: shipping, total: discounted_price + shipping)
}

// Process all orders: extract relevant data
processed_orders = orders$> (order -> process_order(order))

>> "Processed orders (id, original, discounted, shipping, final):" ¶
@ po:processed_orders {
    >> "  Order " >> po.id >> ": $" >> po.orig
    >> " -> $" >> po.disc >> " + $" >> po.ship
    >> " = $" >> po.total ¶
}
¶

// Analytics: Priority orders only
priority_orders = orders$| (o -> o[6])
>> "Priority orders count: " >> priority_orders$# ¶

// Analytics: Total revenue (with discounts and shipping)
total_revenue = processed_orders$< (0, (acc, po) -> acc + po.total)
>> "Total revenue: $" >> total_revenue ¶
¶

// Analytics: Average order value
average_order = total_revenue / processed_orders$#
>> "Average order value: $" >> average_order ¶
¶

// Customer segmentation: Group by customer
customer_501_orders = orders$| (o -> o[2] == 501)
customer_501_total = customer_501_orders$< (0, (acc, o) -> acc + o[4])
>> "Customer 501 total spending: $" >> customer_501_total ¶
¶

// High-value orders (>= $200 after processing)
high_value = processed_orders$| (po -> po.total >= 200)
>> "High-value orders (>=$200 final): " >> high_value$# ¶
¶

// Complex aggregation: Orders with discount AND priority
special_orders = orders$| (o -> o[5] && o[6])

special_count = special_orders$#
>> "Orders with both discount and priority: " >> special_count ¶

special_revenue = special_orders
    $> (o -> apply_discount(o) + calculate_shipping(o))
    $< (0, (acc, x) -> acc + x)

>> "Revenue from special orders: $" >> special_revenue ¶
¶

// Top order by final price
first_po = processed_orders[1]
top1 = processed_orders$< (first_po, (max, po) -> {
    ? po.total > max.total {
        <~ po
    }
    _{
        <~ max
    }
})

>> "Highest value order: #" >> top1.id >> " at $" >> top1.total ¶
¶

// Closure-based discount calculator factory
make_discount_calculator = discount_percent -> (price -> price - price * discount_percent / 100)

discount_20 = make_discount_calculator(20)
discount_30 = make_discount_calculator(30)

>> "Test discount calculators:" ¶
>> "  $100 with 20% off: $" >> discount_20(100) ¶
>> "  $100 with 30% off: $" >> discount_30(100) ¶
¶

>> "=== ALL ANALYTICS COMPLETED ===" ¶
