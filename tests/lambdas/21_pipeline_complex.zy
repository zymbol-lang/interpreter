// Simulate user records: (id, age, score, active)
users = [
    (1, 25, 85, #1),
    (2, 17, 92, #1),
    (3, 30, 78, #0),
    (4, 22, 95, #1),
    (5, 16, 88, #1),
    (6, 35, 65, #1),
    (7, 19, 90, #1),
    (8, 28, 72, #0),
    (9, 21, 98, #1),
    (10, 15, 80, #1)
]

>> "Total users: " >> users$# ¶
¶

// Pipeline: Filter adults (>=18) AND active -> Extract scores -> Calculate average
adults_active = users$| (u -> {
    age = u[2]
    active = u[4]
    is_adult = age >= 18
    <~ is_adult && active
})

>> "Adults (>=18) and active: " >> adults_active$# ¶

scores = adults_active$> (u -> u[3])
>> "Scores: "
@ s:scores {
    >> s " "
}
¶

sum = scores$< (0, (acc, x) -> acc + x)
count = scores$#
average = sum / count

>> "Average score of active adults: " >> average ¶
>> "Expected: (85+95+65+90+98)/5 = 86.6 ≈ 86" ¶
¶

// Find top performer
top_score = scores$< (scores[1], (max, x) -> {
    ? x > max {
        <~ x
    }
    _{
        <~ max
    }
})

>> "Top score: " >> top_score ¶
>> "Expected: 98" ¶
¶

// Chain with pipes
result = users
    $| (u -> u[2] >= 18 && u[4])
    $> (u -> u[3])

top = result$< (result[1], (max, x) -> {
    ? x > max {
        <~ x
    }
    _{
        <~ max
    }
})

>> "Top via pipeline: " >> top ¶
¶

