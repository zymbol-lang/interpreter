// Test: Matrix operations using nested collection operators
>> "=== MATRIX OPERATIONS TEST ===" ¶
¶

// Create a 3x3 matrix
matrix = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]

>> "Original matrix:" ¶
@ row:matrix {
    @ val:row {
        >> val " "
    }
    ¶
}
¶

// Double every element using nested map
doubled = matrix$> (row -> row$> (x -> x * 2))

>> "Doubled matrix:" ¶
@ row:doubled {
    @ val:row {
        >> val " "
    }
    ¶
}
¶

// Calculate row sums
row_sums = matrix$> (row -> row$< (0, (acc, x) -> acc + x))

>> "Row sums: "
@ sum:row_sums {
    >> sum " "
}
>> " (expected: 6 15 24)" ¶
¶

// Filter rows where sum > 10 — inline: compute directly
filtered_matrix = matrix$| (row -> row$< (0, (acc, x) -> acc + x) > 10)

>> "Rows with sum > 10:" ¶
@ row:filtered_matrix {
    @ val:row {
        >> val " "
    }
    ¶
}
¶

// Sum all elements: nested reduce (sum of row sums)
total_sum = matrix$< (0, (acc, row) -> acc + row$< (0, (racc, x) -> racc + x))
>> "Total sum of all elements: " >> total_sum >> " (expected: 45)" ¶
¶

// Zero matrix: nested map with inline expression
indexed = matrix$> (row -> row$> (x -> x * 0))

>> "Zero matrix (all * 0):" ¶
@ row:indexed {
    @ val:row {
        >> val " "
    }
    ¶
}
¶

>> "=== TEST PASSED ===" ¶
