// Test: map with inline lambda expression (direct computation)
>> "Testing block lambda..." ¶

sales = [(100, 5), (250, 3), (75, 10)]

// Inline lambda: direct expression, no intermediate variables needed
revenues = sales$> (sale -> sale[1] * sale[2])

>> "Revenues: "
@ r:revenues {
    >> r " "
}
