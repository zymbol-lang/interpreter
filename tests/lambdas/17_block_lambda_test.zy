// Test block lambda with map - CORRECTED
>> "Testing block lambda..." ¶

sales = [(100, 5), (250, 3), (75, 10)]

// Lambda DEBE ser inline con operadores de colección
revenues = sales$> (sale -> {
    price = sale[1]
    quantity = sale[2]
    result = price * quantity
    <~ result
})

>> "Revenues: "
@ r:revenues {
    >> r " "
}
