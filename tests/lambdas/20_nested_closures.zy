// Test: Nested closures with multiple levels
>> "=== NESTED CLOSURES TEST ===" ¶
¶

// Three levels of closure nesting
base = 100
make_adder = offset -> {
    multiplier = 2
    <~ x -> {
        extra = 10
        <~ (offset + x) * multiplier + base + extra
    }
}

adder_5 = make_adder(5)
result1 = adder_5(3)
>> "Result 1 (offset=5, x=3): " >> result1 ¶
>> "Expected: (5+3)*2 + 100 + 10 = 126" ¶
¶

// Verify closure captures are independent
adder_10 = make_adder(10)
result2 = adder_10(3)
>> "Result 2 (offset=10, x=3): " >> result2 ¶
>> "Expected: (10+3)*2 + 100 + 10 = 136" ¶
¶

// Original adder_5 should still work
result3 = adder_5(7)
>> "Result 3 (offset=5, x=7): " >> result3 ¶
>> "Expected: (5+7)*2 + 100 + 10 = 134" ¶
¶

>> "=== TEST PASSED ===" ¶
