// Test: Nested closures — outer lambda captures outer scope,
// inner lambda captures outer lambda's parameter.
// Note: only lambda *parameters* are captured by inner lambdas,
// not block-local variables (known limitation — see MANUAL L-series).

base = 100

// make_adder returns a lambda that adds offset + x + base
make_adder = offset -> (x -> offset + x + base)

adder_5 = make_adder(5)
result1 = adder_5(3)
>> result1 ¶    // 108  (5 + 3 + 100)

// Closures are independent: adder_10 has its own offset
adder_10 = make_adder(10)
result2 = adder_10(3)
>> result2 ¶    // 113  (10 + 3 + 100)

// Original adder_5 is unaffected by creating adder_10
result3 = adder_5(7)
>> result3 ¶    // 112  (5 + 7 + 100)

// Deeply chained: curry-style add3
add3 = a -> (b -> (c -> a + b + c))
>> add3(1)(2)(3) ¶    // 6
