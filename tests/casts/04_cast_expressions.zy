// Test: Cast operators with non-trivial expressions
// Verifies that ##. ### ##! work on any primary_expr, not just identifiers

// Arithmetic expressions (via grouped expr)
>> ###(7 / 2.0) ¶    // 4  (3.5 rounds to 4)
>> ##!(7 / 2.0) ¶    // 3  (3.5 truncates to 3)
>> ##.(7 / 2) ¶      // 3  (integer 3 cast to Float — displays as 3)

// Nested casts: Int → Float → Int
i = 7
fi = ##.i
ri = ###fi
>> ri ¶    // 7

// Cast in assignment expression
step = 0.1
total = ##.(###(1.0 / step))
>> total ¶    // 10

// Cast in conditional
f = 3.6
? ###f > 3 {
    >> "rounded > 3" ¶
}
? ##!f == 3 {
    >> "truncated == 3" ¶
}

// Cast in HOF
values = [0.5, 1.4, 2.6, 3.5, 4.9]
rounded = values$> (x -> ###x)
truncd  = values$> (x -> ##!x)
>> rounded ¶    // [1, 1, 3, 4, 5]
>> truncd ¶     // [0, 1, 2, 3, 4]

// Cast pipeline with pipe operator
to_int_r = x -> ###x
to_float = x -> ##.x
r = 3.7 |> to_int_r(_) |> to_float(_)
>> r ¶    // 4  (3.7→4→4.0, displayed as 4)
meta = r#?
>> meta[1] ¶    // ##.  (Float type confirmed)
