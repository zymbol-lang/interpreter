// Test: ##! (ToIntTrunc) cast operator
// Converts Float to Int by truncating toward zero (drop fractional part)

// Basic truncation — drops fractional part regardless of value
>> ##!3.9 ¶    // 3  (not 4)
>> ##!3.5 ¶    // 3
>> ##!3.1 ¶    // 3
>> ##!3.0 ¶    // 3

// Negative values — truncates toward zero (less negative than rounding)
>> ##!(-2.9) ¶    // -2  (toward zero, not -3)
>> ##!(-2.5) ¶    // -2
>> ##!(-2.1) ¶    // -2

// Compare ### vs ##! on same value
f = 2.7
>> ###f ¶     // 3  (rounds up)
>> ##!f ¶     // 2  (truncates)

nf = -2.7
>> ###nf ¶    // -3  (rounds away from zero)
>> ##!nf ¶    // -2  (truncates toward zero)

// Type is Int
r = ##!3.9
meta = r#?
>> meta[1] ¶    // ###

// Works in expressions
arr = [1.9, 2.1, 3.5, 4.8, 5.0]
truncated = arr$> (x -> ##!x)
>> truncated ¶    // [1, 2, 3, 4, 5]

// Zero
>> ##!0.0 ¶    // 0
