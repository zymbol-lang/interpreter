// PRACTICAL EXAMPLE: Safe variable access patterns

>> "=== Example 1: Conditional variable creation ===" ¶

create_optional = #1  // Change to #0 to skip creation

? create_optional {
    optional_var = "This variable exists!"
}

// Safe check before using
check = optional_var#?
is_defined = !(check[1] == "##_")

? is_defined {
    >> "Using optional variable: " check[3] ¶
}
_{
    >> "Optional variable not created, using default" ¶
}

¶

>> "=== Example 2: Default values pattern ===" ¶

// Variable might be created in some condition
condition = #0

? condition {
    user_choice = 100
}

// Get value or use default
choice_check = user_choice#?
final_value = #0
is_choice_defined = !(choice_check[1] == "##_")

? is_choice_defined {
    final_value = choice_check[3]
    >> "Using user choice: " final_value ¶
}
_{
    final_value = 50  // Default
    >> "Using default value: " final_value ¶
}

¶

>> "=== Example 3: Safe cleanup check ===" ¶

// Create and process data in a block
? #1 {
    temp_data = [1, 2, 3, 4, 5]
    >> "Processing temporary data..." ¶
}

// Verify it was cleaned up
cleanup_check = temp_data#?
is_cleaned = cleanup_check[1] == "##_"

? is_cleaned {
    >> "✅ Temporary data was properly cleaned up" ¶
}
_{
    >> "❌ WARNING: Temporary data still exists (memory leak)" ¶
}

¶

>> "=== Example 4: Variable existence validation ===" ¶

// Initialize result variable in outer scope
result = ""
process_flag = #1

// Process might update result or leave it empty
? process_flag {
    result = "Processing complete"
}

// Validate result was actually set (not empty)
validation = result#?
is_valid = result == "Processing complete"

? is_valid {
    >> "SUCCESS: " result ¶
}
_{
    >> "ERROR: Processing did not complete" ¶
}

¶
>> "=== All practical examples completed ===" ¶
