// Test: guard patterns with _? in match
temperature = -5
state = ?? temperature {
    _? temperature < 0   : "ice"
    _? temperature < 20  : "cold"
    _? temperature < 35  : "warm"
    _                    : "hot"
}
>> state ¶

// Guard with equality workaround (no multi-value arms)
n = 2
category = ?? n {
    _? n == 1 || n == 2 : "low"
    _? n == 3 || n == 4 : "mid"
    _                   : "high"
}
>> category ¶

// Multiple guards, falls to wildcard
score = 75
grade = ?? score {
    _? score >= 90 : "A"
    _? score >= 80 : "B"
    _? score >= 70 : "C"
    _? score >= 60 : "D"
    _              : "F"
}
>> grade ¶

// Guard on string length (using expression)
word = "hello"
len = word$#
size = ?? len {
    _? len <= 3  : "short"
    _? len <= 6  : "medium"
    _            : "long"
}
>> size ¶
