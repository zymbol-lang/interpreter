// Test: multi-value arms via list patterns (replaces old _? workaround)
classify(n) {
    <~ ?? n {
        [1, 2] : "low"
        [3, 4] : "mid"
        [5, 6] : "high"
        _      : "other"
    }
}

>> classify(1) ¶
>> classify(2) ¶
>> classify(3) ¶
>> classify(4) ¶
>> classify(5) ¶
>> classify(6) ¶
>> classify(9) ¶

// Multi-value string arms
day_type(day) {
    <~ ?? day {
        ["Mon", "Tue", "Wed", "Thu", "Fri"] : "weekday"
        ["Sat", "Sun"]                       : "weekend"
        _                                    : "unknown"
    }
}

>> day_type("Mon") ¶
>> day_type("Sat") ¶
>> day_type("Sun") ¶
