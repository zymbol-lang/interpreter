// Test: functions with output parameters (<~)
// Multiple values via named tuple (positional last-element bug workaround)
divmod(a, b) {
    q = a / b
    r = a % b
    <~ (q: q, r: r)
}

result = divmod(17, 5)
>> result.q ¶
>> result.r ¶

// Named output tuple
minmax(arr) {
    mn = arr[1]
    mx = arr[1]
    @ item:arr {
        ? item < mn { mn = item }
        ? item > mx { mx = item }
    }
    <~ (min: mn, max: mx)
}

data = [3, 1, 4, 1, 5, 9, 2, 6]
bounds = minmax(data)
>> bounds.min ¶
>> bounds.max ¶
