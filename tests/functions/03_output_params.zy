// Test: functions with output parameters (<~)
// Multiple values via tuple
divmod(a, b) {
    q = a / b
    r = a % b
    <~ (q, r)
}

result = divmod(17, 5)
>> result[0] ¶
>> result[1] ¶

// Named output tuple
minmax(arr) {
    mn = arr[0]
    mx = arr[0]
    @ item:arr {
        ? item < mn { mn = item }
        ? item > mx { mx = item }
    }
    <~ (min: mn, max: mx)
}

data = [3, 1, 4, 1, 5, 9, 2, 6]
bounds = minmax(data)
>> bounds.min ¶
>> bounds.max ¶
