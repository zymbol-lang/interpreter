// Test: lambda expressions
double = x -> x * 2
>> double(5) ¶

square = x -> x * x
>> square(7) ¶

// Multi-param lambda
add = (a, b) -> a + b
>> add(3, 4) ¶

// Block lambda with explicit return
clamp = (x, lo, hi) -> {
    ? x < lo { <~ lo }
    ? x > hi { <~ hi }
    <~ x
}
>> clamp(5, 0, 10) ¶
>> clamp(-3, 0, 10) ¶
>> clamp(15, 0, 10) ¶
