// Test: $-[i], $-[i..j], $-- value, $?? value
// All return new collections; originals unchanged.

base = [10, 20, 30, 40, 50]

// в”Ђв”Ђ $-[i] вЂ” remove element at index в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
r1 = base$-[1]        // removes 20 в†’ [10, 30, 40, 50]
>> r1[0] В¶            // в†’ 10
>> r1[1] В¶            // в†’ 30
>> r1$# В¶             // в†’ 4

// в”Ђв”Ђ $-[i] вЂ” remove last via negative index в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
r2 = base$-[-1]       // removes 50 в†’ [10, 20, 30, 40]
>> r2[-1] В¶           // в†’ 40
>> r2$# В¶             // в†’ 4

// в”Ђв”Ђ $-[i..j] вЂ” remove range inclusive в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
r3 = base$-[1..3]     // removes indices 1,2,3 в†’ [10, 50]
>> r3[0] В¶            // в†’ 10
>> r3[1] В¶            // в†’ 50
>> r3$# В¶             // в†’ 2

// в”Ђв”Ђ $-- value вЂ” remove ALL occurrences в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
counts = [1, 2, 1, 3, 1, 4]
clean = counts$-- 1   // в†’ [2, 3, 4]
>> clean[0] В¶         // в†’ 2
>> clean[1] В¶         // в†’ 3
>> clean[2] В¶         // в†’ 4
>> clean$# В¶          // в†’ 3

// в”Ђв”Ђ $?? value вЂ” indices of ALL occurrences в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
positions = counts$?? 1   // в†’ [0, 2, 4]
>> positions[0] В¶     // в†’ 0
>> positions[1] В¶     // в†’ 2
>> positions[2] В¶     // в†’ 4
>> positions$# В¶      // в†’ 3

// в”Ђв”Ђ $?? value not found вЂ” empty array в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
none = base$?? 99
>> none$# В¶           // в†’ 0

// в”Ђв”Ђ Originals unchanged в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
>> base$# В¶           // в†’ 5
>> counts$# В¶         // в†’ 6
