// Test: Array $? contains and $[..] slice (1-based indexing)
/*
arr = [10, 20, 30, 40, 50]
>> (arr$? 30) ¶
>> (arr$? 99) ¶

s1 = arr$[2..3]     // 1-based positions 2,3 → [20, 30]
>> s1 ¶

s2 = arr$[1..5]     // all elements → [10, 20, 30, 40, 50]
>> s2 ¶

s3 = arr$[3..4]     // 1-based positions 3,4 → [30, 40]
>> s3 ¶

*/
arr = [10, 20, 30, 40, 50]
>> arr[1] ¶
>> arr[-1] ¶
>> arr$[1..-1]  ¶
>> arr$[2..-2] ¶
>> arr$[3..-3] ¶