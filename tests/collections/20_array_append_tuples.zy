// Test: $+ append of tuples and named tuples into arrays
// Covers: direct literals, variables, mixed, and field access after append.

// в”Ђв”Ђ Positional tuples вЂ” literal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
arr = []
arr = arr$+ (1, 2, 3)
arr = arr$+ (4, 5, 6)
>> arr$# В¶
>> arr[1][1] В¶
>> arr[2][3] В¶

// в”Ђв”Ђ Positional tuples вЂ” from variable в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
t1 = (10, 20)
t2 = (30, 40)
pts = []
pts = pts$+ t1
pts = pts$+ t2
>> pts$# В¶
>> pts[1][1] В¶
>> pts[1][2] В¶
>> pts[2][1] В¶

// в”Ђв”Ђ Named tuples вЂ” literal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
db = []
db = db$+ (id: 1, name: "Ana",   age: 25, mail: "ana@corp.com")
db = db$+ (id: 2, name: "Bob",   age: 30, mail: "bob@corp.com")
db = db$+ (id: 3, name: "Carla", age: 28, mail: "carla@corp.com")
>> db$# В¶
>> db[1].name В¶
>> db[2].age В¶
>> db[3].mail В¶

// в”Ђв”Ђ Named tuples вЂ” from variable в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
r1 = (id: 4, name: "Dan",  age: 35, mail: "dan@corp.com")
r2 = (id: 5, name: "Eva",  age: 22, mail: "eva@corp.com")
db = db$+ r1
db = db$+ r2
>> db$# В¶
>> db[4].name В¶
>> db[5].name В¶
>> db[5].id В¶

// в”Ђв”Ђ Mixed: positional and named in same array в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
mixed = []
mixed = mixed$+ (0, 0)
mixed = mixed$+ (name: "origin", x: 0, y: 0)
>> mixed$# В¶
>> mixed[1][1] В¶
>> mixed[2].name В¶

// в”Ђв”Ђ Build table in loop then query в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
table = []
@ i:0..4 {
    table = table$+ (id: i, val: i * 10)
}
>> table$# В¶
>> table[1].id В¶
>> table[1].val В¶
>> table[4].id В¶
>> table[4].val В¶

// в”Ђв”Ђ Append and immediately slice в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
base = [(id: 1, name: "A"), (id: 2, name: "B")]
extra = (id: 3, name: "C")
full = base$+ extra
page = full$[2:2]
>> page$# В¶
>> page[1].name В¶
>> page[2].name В¶
