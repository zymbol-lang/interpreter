// Test: $[start:count] and $-[start:count] on named tuples
// 1-based indexing. Each :count case is paired with its ..end equivalent —
// outputs must match.

rec = (id: 1, name: "Ana", age: 25, mail: "ana@x.com", role: "user")

// ── Slice: first 2 fields ─────────────────────────────────────────────────────
s1  = rec$[1:2]
s1b = rec$[1..2]
>> s1$# ¶
>> s1b$# ¶
>> s1[1] ¶
>> s1b[1] ¶

// ── Slice: middle 2 fields (name + age) ──────────────────────────────────────
s2  = rec$[2:2]
s2b = rec$[2..3]
>> s2$# ¶
>> s2b$# ¶
>> s2[1] ¶
>> s2b[1] ¶

// ── Slice: last 2 fields ──────────────────────────────────────────────────────
s3  = rec$[4:2]
s3b = rec$[4..5]
>> s3$# ¶
>> s3b$# ¶
>> s3[1] ¶
>> s3b[1] ¶

// ── Slice: single field ───────────────────────────────────────────────────────
s4  = rec$[3:1]
s4b = rec$[3..3]
>> s4$# ¶
>> s4b$# ¶
>> s4[1] ¶
>> s4b[1] ¶

// ── Slice: count = 0 → empty ──────────────────────────────────────────────────
s5  = rec$[2:0]
s5b = rec$[2..1]
>> s5$# ¶
>> s5b$# ¶

// ── Slice: full named tuple ───────────────────────────────────────────────────
s6  = rec$[1:5]
s6b = rec$[1..5]
>> s6$# ¶
>> s6b$# ¶

// ── Remove: strip last 2 fields (mail + role) ─────────────────────────────────
r1  = rec$-[4:2]
r1b = rec$-[4..5]
>> r1$# ¶
>> r1b$# ¶
>> r1[3] ¶
>> r1b[3] ¶

// ── Remove: single field (age) ────────────────────────────────────────────────
r2  = rec$-[3:1]
r2b = rec$-[3..3]
>> r2$# ¶
>> r2b$# ¶

// ── Remove: first field ───────────────────────────────────────────────────────
r3  = rec$-[1:1]
r3b = rec$-[1..1]
>> r3$# ¶
>> r3b$# ¶
>> r3[1] ¶
>> r3b[1] ¶

// ── Remove: count = 0 → no-op ─────────────────────────────────────────────────
r4  = rec$-[3:0]
r4b = rec$-[3..2]
>> r4$# ¶
>> r4b$# ¶

// ── Remove: all fields ────────────────────────────────────────────────────────
r5  = rec$-[1:5]
r5b = rec$-[1..5]
>> r5$# ¶
>> r5b$# ¶

// ── Variable indices ──────────────────────────────────────────────────────────
from = 2
cnt  = 3

vs  = rec$[from:cnt]
vsb = rec$[2..4]
>> vs$# ¶
>> vsb$# ¶
>> vs[1] ¶
>> vsb[1] ¶

vr  = rec$-[from:cnt]
vrb = rec$-[2..4]
>> vr$# ¶
>> vrb$# ¶
>> vr[1] ¶
>> vrb[1] ¶
