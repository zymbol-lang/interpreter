// Test: $[start:count] and $-[start:count] on named tuples
// Each :count case is paired with its ..end equivalent — outputs must match.

rec = (id: 1, name: "Ana", age: 25, mail: "ana@x.com", role: "user")

// ── Slice: first 2 fields ─────────────────────────────────────────────────────
s1  = rec$[0:2]
s1b = rec$[0..2]
>> s1$# ¶
>> s1b$# ¶
>> s1[0] ¶
>> s1b[0] ¶

// ── Slice: middle 2 fields (name + age) ──────────────────────────────────────
s2  = rec$[1:2]
s2b = rec$[1..3]
>> s2$# ¶
>> s2b$# ¶
>> s2[0] ¶
>> s2b[0] ¶

// ── Slice: last 2 fields ──────────────────────────────────────────────────────
s3  = rec$[3:2]
s3b = rec$[3..5]
>> s3$# ¶
>> s3b$# ¶
>> s3[0] ¶
>> s3b[0] ¶

// ── Slice: single field ───────────────────────────────────────────────────────
s4  = rec$[2:1]
s4b = rec$[2..3]
>> s4$# ¶
>> s4b$# ¶
>> s4[0] ¶
>> s4b[0] ¶

// ── Slice: count = 0 → empty ──────────────────────────────────────────────────
s5  = rec$[1:0]
s5b = rec$[1..1]
>> s5$# ¶
>> s5b$# ¶

// ── Slice: full named tuple ───────────────────────────────────────────────────
s6  = rec$[0:5]
s6b = rec$[0..5]
>> s6$# ¶
>> s6b$# ¶

// ── Remove: strip last 2 fields (mail + role) ─────────────────────────────────
r1  = rec$-[3:2]
r1b = rec$-[3..5]
>> r1$# ¶
>> r1b$# ¶
>> r1[2] ¶
>> r1b[2] ¶

// ── Remove: single field (age) ────────────────────────────────────────────────
r2  = rec$-[2:1]
r2b = rec$-[2..3]
>> r2$# ¶
>> r2b$# ¶

// ── Remove: first field ───────────────────────────────────────────────────────
r3  = rec$-[0:1]
r3b = rec$-[0..1]
>> r3$# ¶
>> r3b$# ¶
>> r3[0] ¶
>> r3b[0] ¶

// ── Remove: count = 0 → no-op ─────────────────────────────────────────────────
r4  = rec$-[2:0]
r4b = rec$-[2..2]
>> r4$# ¶
>> r4b$# ¶

// ── Remove: all fields ────────────────────────────────────────────────────────
r5  = rec$-[0:5]
r5b = rec$-[0..5]
>> r5$# ¶
>> r5b$# ¶

// ── Variable indices ──────────────────────────────────────────────────────────
from = 1
cnt  = 3

vs  = rec$[from:cnt]
vsb = rec$[1..4]
>> vs$# ¶
>> vsb$# ¶
>> vs[0] ¶
>> vsb[0] ¶

vr  = rec$-[from:cnt]
vrb = rec$-[1..4]
>> vr$# ¶
>> vrb$# ¶
>> vr[0] ¶
>> vrb[0] ¶
