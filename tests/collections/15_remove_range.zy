// Test: $-[start..end] remove range (v0.0.2)
arr = [1, 2, 3, 4, 5]
rem1 = arr$-[1..3]
>> rem1 ¶

rem2 = arr$-[0..2]
>> rem2 ¶

rem3 = arr$-[3..5]
>> rem3 ¶

// Open-start range
rem4 = arr$-[..2]
>> rem4 ¶

// Open-end range
rem5 = arr$-[3..]
>> rem5 ¶

// Equal indices — no-op
rem6 = arr$-[2..2]
>> rem6 ¶
