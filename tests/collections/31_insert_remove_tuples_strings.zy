// Test: $+[i], $-[i], $-[i..j], $--, $?? on tuples and strings
// Complements 27_insert_at.zy and 28_remove_ops.zy which focused on arrays.

// в•ђв•ђ TUPLES в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

base_t = (10, 20, 30, 40)

// в”Ђв”Ђ $+[i] insert into tuple в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
t1 = base_t$+[3] 99         // в†’ (10, 20, 99, 30, 40)
>> t1[1] В¶                   // в†’ 10
>> t1[3] В¶                   // в†’ 99
>> t1[4] В¶                   // в†’ 30
>> t1$# В¶                    // в†’ 5

t2 = base_t$+[1] 0           // insert at start в†’ (0, 10, 20, 30, 40)
>> t2[1] В¶                   // в†’ 0
>> t2[2] В¶                   // в†’ 10

// в”Ђв”Ђ $-[i] remove from tuple в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
t3 = base_t$-[2]             // removes 20 в†’ (10, 30, 40)
>> t3[1] В¶                   // в†’ 10
>> t3[2] В¶                   // в†’ 30
>> t3$# В¶                    // в†’ 3

t4 = base_t$-[-1]            // removes last в†’ (10, 20, 30)
>> t4[-1] В¶                  // в†’ 30
>> t4$# В¶                    // в†’ 3

// в”Ђв”Ђ $-[i..j] remove range from tuple в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
t5 = base_t$-[2..3]          // removes positions 2,3 (20,30) в†’ (10, 40)
>> t5[1] В¶                   // в†’ 10
>> t5[2] В¶                   // в†’ 40
>> t5$# В¶                    // в†’ 2

// в”Ђв”Ђ $-- remove all from tuple в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
dup_t = (1, 2, 1, 3, 1, 4)
clean_t = dup_t$-- 1         // в†’ (2, 3, 4)
>> clean_t[1] В¶              // в†’ 2
>> clean_t$# В¶               // в†’ 3

// в”Ђв”Ђ $?? find all positions in tuple в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
pos_t = dup_t$?? 1           // в†’ [1, 3, 5]
>> pos_t[1] В¶                // в†’ 1
>> pos_t[2] В¶                // в†’ 3
>> pos_t[3] В¶                // в†’ 5
>> pos_t$# В¶                 // в†’ 3

// в”Ђв”Ђ Originals unchanged в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
>> base_t$# В¶                // в†’ 4
>> dup_t$# В¶                 // в†’ 6

// в•ђв•ђ STRINGS в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

word = "hello"

// в”Ђв”Ђ $+[i] insert char into string в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
s1 = word$+[1] 'H'           // insert at start в†’ "Hhello"
>> s1[1] В¶                   // в†’ H
>> s1$# В¶                    // в†’ 6

s2 = word$+[6] '!'           // append at end в†’ "hello!"
>> s2[-1] В¶                  // в†’ !
>> s2$# В¶                    // в†’ 6

s3 = word$+[3] 'X'           // insert in middle в†’ "heXllo"
>> s3[3] В¶                   // в†’ X
>> s3[4] В¶                   // в†’ l

// в”Ђв”Ђ $-[i] remove char from string в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
s4 = word$-[1]               // removes 'h' в†’ "ello"
>> s4[1] В¶                   // в†’ e
>> s4$# В¶                    // в†’ 4

s5 = word$-[-1]              // removes last char 'o' в†’ "hell"
>> s5[-1] В¶                  // в†’ l
>> s5$# В¶                    // в†’ 4

// в”Ђв”Ђ $-[i..j] remove range from string в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
s6 = word$-[2..3]            // removes 'e','l' (positions 2,3) в†’ "hlo"
>> s6$# В¶                    // в†’ 3
>> s6[1] В¶                   // в†’ h
>> s6[2] В¶                   // в†’ l

// в”Ђв”Ђ $-- remove all occurrences from string в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
messy = "aabbccaabb"
clean_s = messy$-- "aa"      // removes both "aa" в†’ "bbccbb"
>> clean_s В¶                 // в†’ bbccbb

vowels = "banana"
no_a = vowels$-- "a"         // removes all "a" в†’ "bnn"
>> no_a В¶                    // в†’ bnn

// в”Ђв”Ђ $?? find char positions in string в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
fruit = "banana"
a_pos = fruit$?? "a"         // в†’ [2, 4, 6]
>> a_pos[1] В¶                // в†’ 2
>> a_pos[2] В¶                // в†’ 4
>> a_pos[3] В¶                // в†’ 6
>> a_pos$# В¶                 // в†’ 3

// в”Ђв”Ђ $?? find substring positions в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
haystack = "abcabcabc"
sub_pos = haystack$?? "abc"  // в†’ [1, 4, 7]
>> sub_pos[1] В¶              // в†’ 1
>> sub_pos[2] В¶              // в†’ 4
>> sub_pos[3] В¶              // в†’ 7

// в”Ђв”Ђ Original unchanged в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
>> word В¶                    // в†’ hello
>> word$# В¶                  // в†’ 5
