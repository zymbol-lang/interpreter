// Range on last step — expands columns within a row
// arr[[row>col1..col2]] → [[values in that column range]]
matriz = [[1,2,3], [4,5,6], [7,8,9]]

// Row 1 cols 2-3; Row 2 cols 2-3
>> matriz[[1>2..3] ; [2>2..3]] ¶

// Full matrix reconstruction via ranges
>> matriz[[1>1..3] ; [2>1..3] ; [3>1..3]] ¶
