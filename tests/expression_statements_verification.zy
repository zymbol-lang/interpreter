// =============================================================================
// TEST 15: Complex Nested Calls
// =============================================================================
>> "TEST 15: Complex Nested Calls" ¶

complex_result = 0
helper1(r<~) {
    r = r + 10
}

helper2(r<~) {
    r = r * 2
}

complex_func(result<~) {
    helper1(result)
    helper2(result)
}

complex_func(complex_result)

>> "Complex result: " complex_result ¶  // Expected: 20

? complex_result == 20 {
    >> "✅ TEST 15 PASSED" ¶
}
_{
    >> "❌ TEST 15 FAILED" ¶
}
