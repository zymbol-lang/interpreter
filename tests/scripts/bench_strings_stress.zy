// ============================================================================
// ZYMBOL-LANG — Extended String Stress Test
// 10 scenarios covering: concat, tokenize, slice, char-iter, search,
//                        template-build, word-analysis, chunk, join, format
//
// Run (WT):  time zymbol run tests/scripts/bench_strings_stress.zy
// Run (VM):  time zymbol run --vm tests/scripts/bench_strings_stress.zy
// ============================================================================

<# ./lib_time <= T

>> "=== Zymbol String Stress (Extended) ===" ¶

t_total = T::now()

// ── S1: Heavy concat accumulation ────────────────────────────────────────────
t = T::now()
s = ""
@ i:0..7999 { s = s "x" }
s1_len = s$#
>> "S1_heavy_concat:    len=" s1_len "  " T::elapsed(t) ¶

// ── S2: Repeated tokenization ─────────────────────────────────────────────────
t = T::now()
csv = "alpha,beta,gamma,delta,epsilon,zeta,eta,theta,iota,kappa,lambda,mu,nu"
total_tokens = 0
@ i:0..1999 {
    parts = csv $/ ','
    total_tokens = total_tokens + parts$#
}
>> "S2_tokenize:        total=" total_tokens "  " T::elapsed(t) ¶

// ── S3: Sliding-window slices ─────────────────────────────────────────────────
t = T::now()
text = "the quick brown fox jumps over the lazy dog near the river bank"
slice_total = 0
@ i:0..3999 {
    start = i % 53 + 1
    end = start + 9
    sl = text$[start..end]
    slice_total = slice_total + sl$#
}
>> "S3_sliding_slices:  chars=" slice_total "  " T::elapsed(t) ¶

// ── S4: Char frequency count ──────────────────────────────────────────────────
t = T::now()
corpus = "the quick brown fox jumps over the lazy dog"
vowels = 0
consonants = 0
@ _iter:0..399 {
    @ ch:corpus {
        is_vowel = ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u'
        is_space = ch == ' '
        ? is_vowel { vowels = vowels + 1 }
        ? !is_vowel && !is_space { consonants = consonants + 1 }
    }
}
>> "S4_char_freq:       vowels=" vowels " consonants=" consonants "  " T::elapsed(t) ¶

// ── S5: Multi-pattern substring search ───────────────────────────────────────
t = T::now()
haystack = "artificial intelligence natural language processing machine learning neural network deep"
patterns = ["intel", "lang", "learn", "neural", "deep"]
hits = 0
@ i:1..3000 {
    p = patterns[(i - 1) % 5 + 1]
    ? haystack$? p { hits = hits + 1 }
}
>> "S5_multi_search:    hits=" hits "  " T::elapsed(t) ¶

// ── S6: Template / markup building ───────────────────────────────────────────
t = T::now()
template_total = 0
@ i:0..3999 {
    sq = i * i
    line = "row:" i " sq:" sq " tag:item-" i "-end"
    template_total = template_total + line$#
}
>> "S6_template_build:  chars=" template_total "  " T::elapsed(t) ¶

// ── S7: Word-level analysis ───────────────────────────────────────────────────
t = T::now()
sentence = "the quick brown fox jumps over the lazy dog"
word_chars = 0
long_words = 0
@ _iter:0..999 {
    words = sentence $/ ' '
    @ w:words {
        wlen = w$#
        word_chars = word_chars + wlen
        ? wlen > 4 { long_words = long_words + 1 }
    }
}
>> "S7_word_analysis:   total=" word_chars " long=" long_words "  " T::elapsed(t) ¶

// ── S8: Fixed-size chunk extraction ──────────────────────────────────────────
t = T::now()
data = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
chunk_total = 0
@ i:0..4999 {
    pos = (i * 7) % 57 + 1
    pend = pos + 4
    chunk = data$[pos..pend]
    chunk_total = chunk_total + chunk$#
}
>> "S8_chunk_extract:   total=" chunk_total "  " T::elapsed(t) ¶

// ── S9: Simulated join (accumulate with separator) ────────────────────────────
t = T::now()
wlist = ["one", "two", "three", "four", "five", "six", "seven", "eight", "nine", "ten"]
join_total = 0
@ _iter:0..399 {
    joined = ""
    @ j:1..10 {
        ? j > 1 { joined = joined "," }
        joined = joined wlist[j]
    }
    join_total = join_total + joined$#
}
>> "S9_join_sim:        total=" join_total "  " T::elapsed(t) ¶

// ── S10: Numeric-string formatting ───────────────────────────────────────────
t = T::now()
fmt_total = 0
@ i:0..5999 {
    diff = i - 3000
    score = i * 37 % 1000
    record = "id=" i " diff=" diff " score=" score
    fmt_total = fmt_total + record$#
}
>> "S10_num_format:     chars=" fmt_total "  " T::elapsed(t) ¶

>> "=== Done (" T::total(t_total) ") ===" ¶
