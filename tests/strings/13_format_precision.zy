// Test: Inline precision modifiers for #, and #^
// Forms: #,.N|expr|  #,!N|expr|  #^.N|expr|  #^!N|expr|

// ── Thousands + round (.N) ──────────────────────────────────────
>> #,.2|3141592.653| ¶       // → 3,141,592.65
>> #,.4|3141592.653| ¶       // → 3,141,592.6530
>> #,.0|9876543.9|   ¶       // → 9,876,544  (round to integer)
>> #,.2|1000.0|      ¶       // → 1,000.00

// ── Thousands + truncate (!N) ───────────────────────────────────
>> #,!2|3141592.653| ¶       // → 3,141,592.65
>> #,!4|3141592.653| ¶       // → 3,141,592.6530
>> #,!0|9876543.9|   ¶       // → 9,876,543  (truncate to integer)

// ── Thousands — negative numbers ────────────────────────────────
>> #,.2|-9876.543|   ¶       // → -9,876.54
>> #,!2|-9876.543|   ¶       // → -9,876.54

// ── Thousands — integer input ───────────────────────────────────
>> #,.2|1234567|     ¶       // → 1,234,567.00
>> #,!2|1234567|     ¶       // → 1,234,567.00

// ── Scientific + round (.N) ─────────────────────────────────────
>> #^.3|12345.678|   ¶       // → 1.235e4
>> #^.2|0.000123456| ¶       // → 1.23e-4
>> #^.1|99999.0|     ¶       // → 1.0e5
>> #^.4|12345.678|   ¶       // → 1.2346e4

// ── Scientific + truncate (!N) ──────────────────────────────────
>> #^!3|12345.678|   ¶       // → 1.234e4
>> #^!2|0.000123456| ¶       // → 1.23e-4
>> #^!1|99999.0|     ¶       // → 9.9e4

// ── Scientific — negative numbers ───────────────────────────────
>> #^.2|-0.0056789|  ¶       // → -5.68e-3
>> #^!2|-0.0056789|  ¶       // → -5.67e-3

// ── Expression as argument ──────────────────────────────────────
x = 100
y = 333.3333
>> #,.2|x * y|       ¶       // → 33,333.33
>> #^.3|x * y|       ¶       // → 3.333e4

// ── Variable holding a parsed numeric string ────────────────────
val = #|"9876543.219"|
>> #,.2|val|         ¶       // → 9,876,543.22
>> #^.2|val|         ¶       // → 9.88e6
