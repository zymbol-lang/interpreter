// Test: multiple labeled loops — @:label> and @:label! across nesting levels

// ── Scenario 1: three nested labeled loops ───────────────────────────────
// @:b>  — skips the @:b iteration (inner @:c never runs for j==2)
// @:a!  — exits @:a entirely (fires when i==2 and k==2)
@:a i:1..3 {
    @:b j:1..3 {
        ? j == 2 { @:b> }
        @:c k:1..3 {
            ? i == 2 && k == 2 { @:a! }
            >> "{i}{j}{k} "
        }
    }
}
>> ¶

// ── Scenario 2: @:inner! on inner label, @:outer> on outer label ──────────
// @:inner! — breaks @:inner when j==3 (never adds j==3 or j==4)
// @:outer> — skips rest of @:outer body when i==3 (never adds for i==3)
total = 0
@:outer i:1..4 {
    @:inner j:1..4 {
        ? j == 3 { @:inner! }
        ? i == 3 { @:outer> }
        total += i * j
    }
}
>> total ¶

// ── Scenario 3: @:loop> on outermost label from inside a nested ? block ──
// When i==3: appends "[skip] " and continues to next iteration of @:loop
// The line `out = "{out}{i} "` is never reached for i==3
out = ""
@:loop i:1..5 {
    ? i == 3 {
        out = "{out}[skip] "
        @:loop>
    }
    out = "{out}{i} "
}
>> out ¶
