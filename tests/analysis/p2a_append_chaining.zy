// P2-A: $+ chaining — parse_postfix_structural fix
// arr$+ a$+ b$+ c evaluates left-to-right without extra parentheses

arr = [1, 2, 3]
arr = arr$+ 4$+ 5$+ 6
>> arr ¶

// Chain starting from empty array
empty = []
result = empty$+ "a"$+ "b"$+ "c"
>> result ¶

// Chain on tuple
t = (1, 2)
t2 = t$+ 3$+ 4
>> t2 ¶
